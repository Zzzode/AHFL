// provider_step_graph.def — Provider artifact dependency graph (X-macro table)
//
// This file declaratively encodes the dependency graph for all provider pipeline
// steps. ProviderPipeline::build uses it through provider_artifact_graph to
// prefetch dependencies before invoking the typed artifact builder.
//
// Three macro shapes are used:
//
//   AHFL_PROVIDER_STEP_1(kind, domain_builder, result_field, dep1)
//       A step with exactly one dependency.  The generated builder will:
//         1. Retrieve `dep1` from the cache.
//         2. Invoke `dsi::domain_builder(*dep1)`.
//         3. Render diagnostics, check errors, and return `result.result_field`.
//
//   AHFL_PROVIDER_STEP_2(kind, domain_builder, result_field, dep1, dep2)
//       A step with exactly two dependencies.  The generated builder will:
//         1. Retrieve `dep1` and `dep2` from the cache.
//         2. Invoke `dsi::domain_builder(*dep1, *dep2)`.
//         3. Render diagnostics, check errors, and return `result.result_field`.
//
//   AHFL_PROVIDER_STEP_CUSTOM(kind)
//       A step whose builder requires hand-written logic (complex multi-dep,
//       conditional branching, or non-standard result handling). The
//       implementation lives in `provider/steps/*.cpp` and is maintained
//       manually.
//
// Usage example (code generation):
//
//   #define AHFL_PROVIDER_STEP_1(kind, builder, field, d1) \
//       /* generate build_##kind##_for_cli(...) */
//   #define AHFL_PROVIDER_STEP_2(kind, builder, field, d1, d2) \
//       /* generate build_##kind##_for_cli(...) */
//   #define AHFL_PROVIDER_STEP_CUSTOM(kind) /* skip or forward-declare */
//   #include "provider_step_graph.def"
//

// ─── Guard: all three macros must be defined before inclusion ────────────────

#ifndef AHFL_PROVIDER_STEP_1
#error "AHFL_PROVIDER_STEP_1(kind, domain_builder, result_field, dep1) must be defined before including provider_step_graph.def"
#endif

#ifndef AHFL_PROVIDER_STEP_2
#error "AHFL_PROVIDER_STEP_2(kind, domain_builder, result_field, dep1, dep2) must be defined before including provider_step_graph.def"
#endif

#ifndef AHFL_PROVIDER_STEP_CUSTOM
#error "AHFL_PROVIDER_STEP_CUSTOM(kind) must be defined before including provider_step_graph.def"
#endif

// ═══════════════════════════════════════════════════════════════════════════════
// Custom nodes — complex multi-dep or special logic (manual implementation)
// ═══════════════════════════════════════════════════════════════════════════════

AHFL_PROVIDER_STEP_CUSTOM(WriteAttempt)
AHFL_PROVIDER_STEP_CUSTOM(RecoveryHandoff)
AHFL_PROVIDER_STEP_CUSTOM(DriverBinding)
AHFL_PROVIDER_STEP_CUSTOM(DriverReadiness)
AHFL_PROVIDER_STEP_CUSTOM(ProductionReadinessEvidence)
AHFL_PROVIDER_STEP_CUSTOM(ConformanceReport)
AHFL_PROVIDER_STEP_CUSTOM(SchemaCompatibilityReport)
AHFL_PROVIDER_STEP_CUSTOM(ReleaseEvidenceArchiveManifest)
AHFL_PROVIDER_STEP_CUSTOM(ApprovalReceipt)
AHFL_PROVIDER_STEP_CUSTOM(OptInDecisionReport)
AHFL_PROVIDER_STEP_CUSTOM(RuntimePolicyReport)
AHFL_PROVIDER_STEP_CUSTOM(ProductionIntegrationDryRunReport)

