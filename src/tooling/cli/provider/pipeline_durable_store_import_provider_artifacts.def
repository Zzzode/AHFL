// This file intentionally has no include guard. Include it with
// AHFL_CLI_DURABLE_STORE_IMPORT_PROVIDER_ARTIFACT defined.
//
// Fields:
//   kind           ProviderArtifactKind enumerator
//   artifact_type  durable_store_import model type
//   builder        internal provider pipeline node builder
//   printer        stable artifact printer facade
//   artifact_id    provider-local artifact id used by `ahflc emit provider/...`
//   visibility     Public (top-level meaningful pipeline output) or
//                  Internal (intermediate pipeline node)
//   order          provider-local CLI/list order derived from DAG locality
//   dep_count      number of provider-local dependencies
//   deps           ProviderArtifactKind dependency list

#ifndef AHFL_CLI_DURABLE_STORE_IMPORT_PROVIDER_ARTIFACT
#error "Define AHFL_CLI_DURABLE_STORE_IMPORT_PROVIDER_ARTIFACT before including this file."
#endif

#ifndef AHFL_PROVIDER_DEPS
#define AHFL_PROVIDER_DEPS(...) {__VA_ARGS__}
#define AHFL_PROVIDER_DEPS_DEFINED_BY_ARTIFACTS
#endif

