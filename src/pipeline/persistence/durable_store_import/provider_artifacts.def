// This file intentionally has no include guard. Include it with
// AHFL_DURABLE_STORE_IMPORT_PROVIDER_ARTIFACT defined.
//
// Fields:
//   artifact_id     stable kebab-case provider artifact identifier
//   type_name       C++ artifact model type
//   format_version  stable provider artifact format-version constant
//   domain          provider pipeline domain
//   role            contract role inside the domain
//   source_header   leaf header that owns the model type

#ifndef AHFL_DURABLE_STORE_IMPORT_PROVIDER_ARTIFACT
#error "Define AHFL_DURABLE_STORE_IMPORT_PROVIDER_ARTIFACT before including this file."
#endif

