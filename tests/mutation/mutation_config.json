{
    "mutation_testing": {
        "tool": "mull",
        "version": "0.21.0",
        "targets": [
            "ahfl_compiler_syntax",
            "ahfl_compiler_ir",
            "ahfl_verification_formal"
        ],
        "test_suites": [
            "ahfl_project_parse_tests",
            "ahfl_project_check_tests",
            "ahfl_bmc_tests"
        ],
        "mutators": [
            "cxx_add_to_sub",
            "cxx_remove_void_call",
            "cxx_replace_scalar_value",
            "cxx_logical_and_to_or",
            "cxx_logical_or_to_and",
            "cxx_le_to_lt",
            "cxx_lt_to_le",
            "cxx_ge_to_gt",
            "cxx_gt_to_ge"
        ],
        "timeout_factor": 3,
        "exclude_paths": [
            "third_party/",
            "tests/"
        ],
        "report_format": "json",
        "report_dir": "mutation_reports"
    }
}
