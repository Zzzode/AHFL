module refund_audit::private_child_import;

import audit_core::lib::internal as internal;

struct RefundAuditInput {
    order_id: String;
}

struct RefundAuditOutput {
    tag: internal::InternalPolicy;
}

workflow BadPrivateChildImportWorkflow {
    input: RefundAuditInput;
    output: RefundAuditOutput;
    return: RefundAuditOutput {
        tag: internal::InternalPolicy {
            value: input.order_id,
        },
    };
}
