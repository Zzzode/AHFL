module refund_audit::main;

import audit_core::lib as core;
import std::option as option;

struct RefundAuditInput {
    order_id: String;
}

struct RefundAuditOutput {
    accepted: Bool;
}

struct Envelope {
    request: core::AuditRequest;
    maybe_score: option::Option<Int>;
}

workflow RefundAuditWorkflow {
    input: RefundAuditInput;
    output: RefundAuditOutput;
    return: RefundAuditOutput {
        accepted: true,
    };
}
