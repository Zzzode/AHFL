module stdlib_units::result_ut;

import std::result as result;
import std::option as option;

// Result<T, E> unit-test matrix (corelib-support-workplan M1-7 / blocker B3).
// 28 assertions: 14 positive (Ok) + 14 boundary (Err). Method-form surface.
// Generic methods carry explicit type args because P3 does not propagate U/F
// inference across a method chain into the receiver of the next call.
fn result_ut() -> Int effect Pure decreases 0 {
    let ok: result::Result<Int, String> = result::Result::Ok(5);
    let err: result::Result<Int, String> = result::Result::Err("boom");

    // ===== 14 positive: Ok operations =====
    assert(ok.is_ok());
    assert(ok.map<Int>(\x: Int -> x * 2).unwrap_or(0) == 10);
    assert(ok.map<Int>(\x: Int -> x + 1).is_ok());
    assert(ok.map_err<String>(\e: String -> e).unwrap_or(0) == 5);
    assert(ok.and_then<Int>(\x: Int -> result::Result::Ok(x * 3)).unwrap_or(0) == 6);
    assert(ok.and_then<Int>(\x: Int -> result::Result::Ok(x + 1)).is_ok());
    assert(ok.or_else<String>(\e: String -> result::Result::Ok(0)).unwrap_or(0) == 5);
    assert(ok.unwrap_or(0) == 5);
    assert(ok.unwrap_or_else(\e: String -> 0) == 5);
    assert(ok.ok().is_some());
    assert(ok.err().is_none());
    // flat_map (M1-1): alias of and_then, mirrors Option / List.
    assert(result::flat_map<Int, Int, String>(ok, \x: Int -> result::Result::Ok(x * 3)).unwrap_or(0) == 6);
    assert(result::flat_map<Int, Int, String>(err, \x: Int -> result::Result::Ok(x * 3)).is_err());
    // flatten (M1-3): Result<Result<T,E>,E> -> Result<T,E>
    let inner_ok: result::Result<Int, String> = result::Result::Ok(5);
    let nested_ok: result::Result<result::Result<Int, String>, String> = result::Result::Ok(inner_ok);
    assert(result::flatten<Int, String>(nested_ok).unwrap_or(0) == 5);
    let nested_outer_err: result::Result<result::Result<Int, String>, String> = result::Result::Err("boom");
    assert(result::flatten<Int, String>(nested_outer_err).is_err());
    let inner_err: result::Result<Int, String> = result::Result::Err("inner");
    let nested_inner_err: result::Result<result::Result<Int, String>, String> = result::Result::Ok(inner_err);
    assert(result::flatten<Int, String>(nested_inner_err).is_err());
    // transpose (M1-3): Result<Option<T>,E> -> Option<Result<T,E>>
    let some_v: option::Option<Int> = option::Option::Some(7);
    let r_ok_some: result::Result<option::Option<Int>, String> = result::Result::Ok(some_v);
    assert(result::transpose<Int, String>(r_ok_some).is_some());
    let none_v: option::Option<Int> = option::Option::None;
    let r_ok_none: result::Result<option::Option<Int>, String> = result::Result::Ok(none_v);
    assert(result::transpose<Int, String>(r_ok_none).is_none());
    let r_err_t: result::Result<option::Option<Int>, String> = result::Result::Err("boom");
    assert(result::transpose<Int, String>(r_err_t).is_some());
    assert(result::from_option<Int, String>(option::Option::Some(7), \ -> "x").is_ok());
    assert(result::from_option<Int, String>(option::Option::Some(7), \ -> "x").unwrap_or(0) == 7);
    let hundred: result::Result<Int, String> = result::Result::Ok(100);
    assert(hundred.is_ok());

    // ===== 14 boundary: Err operations =====
    assert(err.is_err());
    assert(err.unwrap_or(99) == 99);
    assert(err.unwrap_or_else(\e: String -> 99) == 99);
    assert(err.map<Int>(\x: Int -> x + 1).is_err());
    assert(err.map<Int>(\x: Int -> x + 1).unwrap_or(42) == 42);
    assert(err.map_err<String>(\e: String -> "mapped").is_err());
    assert(err.and_then<Int>(\x: Int -> result::Result::Ok(x)).is_err());
    assert(err.and_then<Int>(\x: Int -> result::Result::Ok(x)).unwrap_or(7) == 7);
    assert(err.or_else<String>(\e: String -> result::Result::Ok(11)).unwrap_or(0) == 11);
    assert(err.or_else<String>(\e: String -> result::Result::Err("other")).is_err());
    assert(err.ok().is_none());
    assert(err.err().is_some());
    assert(result::from_option<Int, String>(option::Option::None, \ -> "x").is_err());
    let zerr: result::Result<Int, String> = result::Result::Err("z");
    assert(zerr.is_err());

    return 0;
}
