module stdlib_units::string_ut;

import std::string as string;
import std::collections as collections;

// String unit-test matrix (corelib-support-workplan M1-7 / blocker B3).
// 29 assertions: 15 positive + 14 boundary. Method-form surface.
// NOTE: contains/starts_with/ends_with route to @builtin hooks declared in
// the known-hook whitelist; they type-check here (runtime impl is M1-4 follow-up).
fn string_ut() -> Int effect Pure decreases 0 {
    let s: String = "hello";
    let e: String = "";
    let words: collections::List<String> = collections::list_from_array<String>("a", "b", "c");

    // ===== 15 positive =====
    assert(s.length() == 5);
    assert(s.concat(" world").length() == 11);
    assert(s.starts_with("hel"));
    assert(s.ends_with("llo"));
    assert(s.contains("ell"));
    assert(s.substring(0, 3).length() == 3);
    assert(s.substring(1, 4).contains("ell"));
    assert(s.repeat(2).length() == 10);
    assert(s.repeat(3).starts_with("hello"));
    assert(s.repeat(1).length() == 5);
    assert(string::concat("ab", "cd").length() == 4);
    assert(string::join(words, ",").length() == 5);
    assert(string::join(words, ",").contains(","));
    assert(s.substring(0, 5).length() == 5);
    assert(s.concat("!").ends_with("!"));

    // ===== 14 boundary =====
    assert(e.is_empty());
    assert(e.length() == 0);
    assert(e.repeat(5).is_empty());
    assert(e.concat("x").length() == 1);
    assert(e.starts_with(""));
    assert(s.starts_with(""));
    assert(s.ends_with(""));
    assert(s.contains(""));
    assert(s.substring(0, 0).is_empty());
    assert(e.repeat(0).is_empty());
    assert(string::concat("", "").is_empty());
    assert(s.repeat(0).length() == 0);
    assert(s.concat("").length() == 5);
    assert(string::join(words, "").length() == 3);

    // ===== trim / replace (M1-4 new hooks) =====
    assert(s.trim().length() == 5);
    assert("  hi  ".trim().length() == 2);
    assert("  hi  ".trim_start().length() == 4);
    assert("  hi  ".trim_end().length() == 4);
    assert(e.trim().length() == 0);
    assert("   ".trim().length() == 0);
    assert(s.replace("l", "L").length() == 5);
    assert(s.replace("l", "LL").length() == 7);
    assert(s.replace("xyz", "Q").length() == 5);
    assert(s.replace("", "Q").length() == 5);
    assert("a-b-c".replace("-", "+").length() == 5);

    // ===== split / parse_int (M1-4 new hooks) =====
    assert(collections::length<String>("a,b,c".split(",")) == 3);
    assert(collections::length<String>("hello".split(",")) == 1);
    assert(collections::length<String>("".split(",")) == 1);
    assert(collections::length<String>("abc".split("")) == 3);
    assert(collections::length<String>("a,,b".split(",")) == 3);
    assert("42".parse_int().is_some());
    assert("42".parse_int().unwrap_or(0) == 42);
    assert("-7".parse_int().is_some());
    assert("-7".parse_int().unwrap_or(0) == -7);
    assert("xyz".parse_int().is_none());
    assert("12abc".parse_int().is_none());

    // ===== split_whitespace / parse_float (M1-4) =====
    assert(collections::length<String>("a b  c".split_whitespace()) == 3);
    assert(collections::length<String>("  hi  ".split_whitespace()) == 1);
    assert(collections::length<String>("".split_whitespace()) == 0);
    assert("3.14".parse_float().is_some());
    assert("-0.5".parse_float().is_some());
    assert("xyz".parse_float().is_none());
    assert("3.14abc".parse_float().is_none());

    return 0;
}
