    workflow__formal_flow_workflow_ReviewWorkflow__node__second__state = Init : {FastTrack, Review};
    workflow__formal_flow_workflow_ReviewWorkflow__node__second__state = FastTrack : Done;
    workflow__formal_flow_workflow_ReviewWorkflow__node__second__state = Review : Done;
    workflow__formal_flow_workflow_ReviewWorkflow__node__second__state = Done : Done;
    TRUE : workflow__formal_flow_workflow_ReviewWorkflow__node__second__state;
  esac;
  init(workflow__formal_flow_workflow_ReviewWorkflow__node__second__started) := FALSE;
  next(workflow__formal_flow_workflow_ReviewWorkflow__node__second__started) := case
