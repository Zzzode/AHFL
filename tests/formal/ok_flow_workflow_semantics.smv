-- AHFL restricted SMV backend v0.1
-- This lowering preserves validated state-machine, flow, and workflow structure.
-- Pure embedded expressions are abstracted as boolean observation variables.
MODULE main
VAR
  agent__formal_flow_workflow_ReviewAgent__state : {Init, FastTrack, Review, Done};
  workflow__formal_flow_workflow_ReviewWorkflow__node__first__state : {Init, FastTrack, Review, Done};
  workflow__formal_flow_workflow_ReviewWorkflow__node__first__started : boolean;
  workflow__formal_flow_workflow_ReviewWorkflow__node__first__completed : boolean;
  workflow__formal_flow_workflow_ReviewWorkflow__node__second__state : {Init, FastTrack, Review, Done};
  workflow__formal_flow_workflow_ReviewWorkflow__node__second__started : boolean;
  workflow__formal_flow_workflow_ReviewWorkflow__node__second__completed : boolean;
