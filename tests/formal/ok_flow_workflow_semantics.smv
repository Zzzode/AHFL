    workflow__formal_flow_workflow_ReviewWorkflow__node__second__started & (workflow__formal_flow_workflow_ReviewWorkflow__node__second__state = Done) : TRUE;
    TRUE : FALSE;
  esac;
-- workflow formal::flow_workflow::ReviewWorkflow safety[0]
LTLSPEC G ((! (workflow__formal_flow_workflow_ReviewWorkflow__node__second__running) | workflow__formal_flow_workflow_ReviewWorkflow__node__first__completed))
-- workflow formal::flow_workflow::ReviewWorkflow safety[1]
LTLSPEC G ((! (workflow__formal_flow_workflow_ReviewWorkflow__node__first__running) | workflow_formal_flow_workflow_ReviewWorkflow_safety_1_atom_0))
-- workflow formal::flow_workflow::ReviewWorkflow liveness[0]
LTLSPEC F ((workflow__formal_flow_workflow_ReviewWorkflow__node__second__completed & (workflow__formal_flow_workflow_ReviewWorkflow__node__second__state = Done)))
