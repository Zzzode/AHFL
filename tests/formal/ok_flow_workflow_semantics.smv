DEFINE
  workflow__formal_flow_workflow_ReviewWorkflow__node__first__running := workflow__formal_flow_workflow_ReviewWorkflow__node__first__started & !(workflow__formal_flow_workflow_ReviewWorkflow__node__first__completed);
  workflow__formal_flow_workflow_ReviewWorkflow__node__second__running := workflow__formal_flow_workflow_ReviewWorkflow__node__second__started & !(workflow__formal_flow_workflow_ReviewWorkflow__node__second__completed);
ASSIGN
  init(agent__formal_flow_workflow_ReviewAgent__state) := Init;
  next(agent__formal_flow_workflow_ReviewAgent__state) := case
    agent__formal_flow_workflow_ReviewAgent__state = Init : {FastTrack, Review};
    agent__formal_flow_workflow_ReviewAgent__state = FastTrack : Done;
    agent__formal_flow_workflow_ReviewAgent__state = Review : Done;
    agent__formal_flow_workflow_ReviewAgent__state = Done : Done;
    TRUE : agent__formal_flow_workflow_ReviewAgent__state;
  esac;
  init(workflow__formal_flow_workflow_ReviewWorkflow__node__first__state) := Init;
  next(workflow__formal_flow_workflow_ReviewWorkflow__node__first__state) := case
    workflow__formal_flow_workflow_ReviewWorkflow__node__first__state = Init : {FastTrack, Review};
    workflow__formal_flow_workflow_ReviewWorkflow__node__first__state = FastTrack : Done;
    workflow__formal_flow_workflow_ReviewWorkflow__node__first__state = Review : Done;
    workflow__formal_flow_workflow_ReviewWorkflow__node__first__state = Done : Done;
    TRUE : workflow__formal_flow_workflow_ReviewWorkflow__node__first__state;
  esac;
  init(workflow__formal_flow_workflow_ReviewWorkflow__node__first__started) := TRUE;
  next(workflow__formal_flow_workflow_ReviewWorkflow__node__first__started) := TRUE;
  init(workflow__formal_flow_workflow_ReviewWorkflow__node__first__completed) := FALSE;
  next(workflow__formal_flow_workflow_ReviewWorkflow__node__first__completed) := case
