-- AHFL restricted SMV backend v0.1
-- This lowering preserves validated state-machine, flow, and workflow structure.
-- Embedded data predicates are exported as environment observation assumptions.
-- Capability calls/effects are bound to flow handler events where available.
-- AHFL_MAP agent__lib_agents_AliasAgent__called__lib_agents_Echo => agent lib::agents::AliasAgent called lib::agents::Echo
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__state => workflow app::main::MainWorkflow node run state
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__phase => workflow app::main::MainWorkflow node run lifecycle phase
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__failure_requested => workflow app::main::MainWorkflow node run environment failure request
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__started => workflow app::main::MainWorkflow node run has started
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__running => workflow app::main::MainWorkflow node run is running
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__completed => workflow app::main::MainWorkflow node run completed
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__failed => workflow app::main::MainWorkflow node run failed
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__recovering => workflow app::main::MainWorkflow node run recovering
-- AHFL_MAP workflow__app_main_MainWorkflow__node__run__recovered => workflow app::main::MainWorkflow node run recovered
MODULE main
VAR
  workflow__app_main_MainWorkflow__node__run__state : {Init, Done};
  workflow__app_main_MainWorkflow__node__run__phase : {AHFL_NODE_IDLE, AHFL_NODE_RUNNING, AHFL_NODE_COMPLETED, AHFL_NODE_FAILED, AHFL_NODE_RECOVERING, AHFL_NODE_RECOVERED, AHFL_NODE_COMPENSATING, AHFL_NODE_COMPENSATED, AHFL_NODE_TERMINAL_FAILED};
IVAR
  workflow__app_main_MainWorkflow__node__run__failure_requested : boolean;
DEFINE
  workflow__app_main_MainWorkflow__node__run__started := !(workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_IDLE);
  workflow__app_main_MainWorkflow__node__run__completed := (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_COMPLETED | (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RUNNING & (workflow__app_main_MainWorkflow__node__run__state = Done)));
  workflow__app_main_MainWorkflow__node__run__running := (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RUNNING & !((workflow__app_main_MainWorkflow__node__run__state = Done)));
  workflow__app_main_MainWorkflow__node__run__failed := (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_FAILED | workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_TERMINAL_FAILED);
  workflow__app_main_MainWorkflow__node__run__recovering := (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERING | workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_COMPENSATING);
  workflow__app_main_MainWorkflow__node__run__recovered := (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERED | workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_COMPENSATED);
  agent__lib_agents_AliasAgent__called__lib_agents_Echo := FALSE;
ASSIGN
  init(workflow__app_main_MainWorkflow__node__run__state) := Init;
  next(workflow__app_main_MainWorkflow__node__run__state) := case
    !(workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RUNNING) : workflow__app_main_MainWorkflow__node__run__state;
    workflow__app_main_MainWorkflow__node__run__state = Init : Done;
    workflow__app_main_MainWorkflow__node__run__state = Done : Done;
    TRUE : workflow__app_main_MainWorkflow__node__run__state;
  esac;
  init(workflow__app_main_MainWorkflow__node__run__phase) := AHFL_NODE_RUNNING;
  next(workflow__app_main_MainWorkflow__node__run__phase) := case
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_COMPLETED : AHFL_NODE_COMPLETED;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_TERMINAL_FAILED : AHFL_NODE_TERMINAL_FAILED;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_COMPENSATED : AHFL_NODE_TERMINAL_FAILED;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_COMPENSATING : AHFL_NODE_COMPENSATED;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERED : AHFL_NODE_RUNNING;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERING : AHFL_NODE_RECOVERED;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_FAILED : AHFL_NODE_RECOVERING;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_IDLE & (TRUE) : AHFL_NODE_RUNNING;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_IDLE : AHFL_NODE_IDLE;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RUNNING & (workflow__app_main_MainWorkflow__node__run__state = Done) : AHFL_NODE_COMPLETED;
    workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RUNNING & workflow__app_main_MainWorkflow__node__run__failure_requested : AHFL_NODE_FAILED;
    TRUE : workflow__app_main_MainWorkflow__node__run__phase;
  esac;
-- workflow app::main::MainWorkflow node run lifecycle[completed_final]
LTLSPEC G (workflow__app_main_MainWorkflow__node__run__completed -> (workflow__app_main_MainWorkflow__node__run__state = Done))
-- workflow app::main::MainWorkflow node run recovery[failed_enters_recovering]
LTLSPEC G ((workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_FAILED) -> F (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERING))
-- workflow app::main::MainWorkflow node run recovery[recovering_enters_recovered]
LTLSPEC G ((workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERING) -> F (workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERED))
-- workflow app::main::MainWorkflow node run recovery[recovered_resumes_running]
LTLSPEC G ((workflow__app_main_MainWorkflow__node__run__phase = AHFL_NODE_RECOVERED) -> F (workflow__app_main_MainWorkflow__node__run__running | workflow__app_main_MainWorkflow__node__run__completed))
-- workflow app::main::MainWorkflow liveness[0]
LTLSPEC (G (!workflow__app_main_MainWorkflow__node__run__failure_requested) -> (F ((workflow__app_main_MainWorkflow__node__run__completed & (workflow__app_main_MainWorkflow__node__run__state = Done)))))
