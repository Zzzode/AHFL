module formal::fail_smv_control;

struct Request {
    value: String;
}

struct Context {
    value: String = "seed";
}

struct Response {
    value: String;
}

agent ControlAgent {
    input: Request;
    context: Context;
    output: Response;
    states: [Init, Done];
    initial: Init;
    final: [Done];
    capabilities: [];
    transition Init -> Done;
}

flow for ControlAgent {
    state Init {
        goto Done;
    }

    state Done {
        return Response {
            value: input.value,
        };
    }
}

workflow FailingControlWorkflow {
    input: Request;
    output: Response;

    node run: ControlAgent(input);

    safety: always not completed(run);

    return: run;
}
