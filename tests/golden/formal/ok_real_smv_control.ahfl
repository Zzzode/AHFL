module formal::real_smv_control;

struct Request {
    value: String;
}

struct Context {
    value: String = "seed";
}

struct Response {
    value: String;
}

agent ControlAgent {
    input: Request;
    context: Context;
    output: Response;
    states: [Init, Done];
    initial: Init;
    final: [Done];
    capabilities: [];
    transition Init -> Done;
}

flow for ControlAgent {
    state Init {
        goto Done;
    }

    state Done {
        return Response {
            value: input.value,
        };
    }
}

workflow ControlWorkflow {
    input: Request;
    output: Response;

    node run: ControlAgent(input);

    safety: always (not running(run) or eventually completed(run));
    liveness: eventually completed(run, Done);

    return: run;
}
