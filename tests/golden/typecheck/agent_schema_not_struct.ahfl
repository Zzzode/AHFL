enum Status {
    Pending,
    Done,
}

type InputAlias = Status;
type ContextAlias = Int;
type OutputAlias = String;

agent InvalidAgent {
    input: InputAlias;
    context: ContextAlias;
    output: OutputAlias;
    states: [Init, Done];
    initial: Init;
    final: [Done];
    capabilities: [];
    transition Init -> Done;
}
