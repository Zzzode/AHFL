struct Request {
    value: String;
}

struct Context {
    value: String = "pending";
}

struct Response {
    value: String;
}

agent BadOutputAgent {
    input: Request;
    context: Context;
    output: Response;
    states: [Init, Done];
    initial: Init;
    final: [Done];
    capabilities: [];
    transition Init -> Done;
}

flow for BadOutputAgent {
    state Init {
        goto Done;
    }

    state Done {
        return Request {
            value: input.value,
        };
    }
}
