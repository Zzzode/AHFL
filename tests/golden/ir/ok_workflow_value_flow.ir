@provenance(module=ir::workflow_value_flow, source=ir/workflow_value_flow.ahfl)
workflow ir::workflow_value_flow::ValueFlowWorkflow {
  input: ir::workflow_value_flow::Request
  output: ir::workflow_value_flow::Response
  node first: ir::workflow_value_flow::EchoAgent(input)
    input_summary {
      reads: [workflow_input(input)]
    }
  node second: ir::workflow_value_flow::EchoAgent(ir::workflow_value_flow::Request { value: first.value }) after [first]
    input_summary {
      reads: [workflow_node_output(first.value)]
    }
  return_summary {
    reads: [workflow_node_output(second.value)]
  }
  return: ir::workflow_value_flow::Response { value: second.value }
}
