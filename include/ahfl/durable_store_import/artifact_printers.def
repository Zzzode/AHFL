// This file intentionally has no include guard. Include it with
// AHFL_DURABLE_STORE_IMPORT_ARTIFACT_PRINTER defined.
//
// Fields:
//   public_name      stable ahfl:: printer facade
//   artifact_type    durable_store_import artifact model type
//   parameter_name   readable facade parameter name
//   detail_namespace implementation namespace under durable_store_import_artifacts_detail
//   detail_name      implementation printer function
//   output_format    machine-readable format category
//   domain           durable import pipeline domain
//   artifact_id      stable kebab-case artifact identifier

#ifndef AHFL_DURABLE_STORE_IMPORT_ARTIFACT_PRINTER
#error "Define AHFL_DURABLE_STORE_IMPORT_ARTIFACT_PRINTER before including this file."
#endif

